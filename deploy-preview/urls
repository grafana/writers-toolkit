#!/usr/bin/env bash

set -euf -o pipefail

if [[ -n "${RUNNER_DEBUG+x}" ]]; then
  set -x
fi

# All input comes from environment variables that are capitalized by convention in this script.
readonly GITHUB_OUTPUT="${GITHUB_OUTPUT:-/dev/stdout}"
readonly SOURCES="${SOURCES:-[]}"
readonly URL="${URL:-}"

if ! jq -e . <<<"${SOURCES}" >/dev/null; then
  echo "SOURCES environment variable is not valid JSON"

  exit 1
fi

visible_sources="$(jq -c '[.[] | select(.include_in_output_links != false)]' <<<"${SOURCES}")"
if [[ "$(jq 'length' <<<"${visible_sources}")" -eq 0 ]]; then
  visible_sources="${SOURCES}"
fi

primary_relative_prefix="$(jq -r '.[0].relative_prefix // ""' <<<"${visible_sources}")"
printf 'primary_relative_prefix=%s\n' "${primary_relative_prefix}" >> "${GITHUB_OUTPUT}"

echo "urls<<EOF" >> "${GITHUB_OUTPUT}"
while read -r relative_prefix; do
  echo "- ${URL}${relative_prefix}" >> "${GITHUB_OUTPUT}"
done < <(jq -r '.[].relative_prefix' <<<"${visible_sources}")
echo "EOF" >> "${GITHUB_OUTPUT}"
