#!/usr/bin/env bash

# Resolve preview path inputs for deploy-preview.
#
# Maps the PR base ref to a documentation target and substitutes any trailing
# "/next" or "/latest" segment in each source's website_directory and
# relative_prefix:
#
#   main           -> next
#   anything else  -> latest

set -euf -o pipefail

if [[ -n "${RUNNER_DEBUG+x}" ]]; then
  set -x
fi

readonly GITHUB_OUTPUT="${GITHUB_OUTPUT:-/dev/stdout}"
readonly BASE_SOURCES="${BASE_SOURCES:-}"
readonly TARGET_REF_NAME="${TARGET_REF_NAME:-}"

if [[ "${TARGET_REF_NAME}" == "main" ]]; then
  target="next"
else
  target="latest"
fi

sources="${BASE_SOURCES}"

if [[ -n "${sources}" ]]; then
  sources="$(jq -c --arg target "${target}" 'map(
    if (((.website_directory // "") | sub("/$"; "")) | test("(^|/)(next|latest)$")) then
      .website_directory |= ((. // "") | sub("/$"; "") | sub("/(next|latest)$"; "/" + $target))
      | .relative_prefix |= if . == null or . == "" then . else ((. | sub("/$"; "") | sub("/(next|latest)$"; "/" + $target)) + "/") end
    else
      .
    end
  )' <<<"${sources}")"
fi

echo "sources=${sources}" >> "${GITHUB_OUTPUT}"
