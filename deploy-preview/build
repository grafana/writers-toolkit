#!/usr/bin/env bash

set -euf -o pipefail

if [[ -n "${RUNNER_DEBUG+x}" ]]; then
  set -x
fi

# Legacy build.
if [[ -n "${WEBSITE_DIRECTORY}" ]]; then
  echo "::warning ::Using legacy inputs. Reach out to #docs-platform (https://raintank-corp.slack.com/archives/C07R2REUULS) to update."

  readonly WEBSITE_DIRECTORY="${WEBSITE_DIRECTORY:-}"
  readonly SOURCE_DIRECTORY="${SOURCE_DIRECTORY:-}"
  readonly REPO="${REPO:-}"
  readonly INDEX_FILE="${INDEX_FILE:-false}"

  docker run \
         -v "${PWD}/dist:/hugo/dist" \
         -v "${PWD}/${SOURCE_DIRECTORY}:/hugo/${WEBSITE_DIRECTORY}" \
         -e INDEX_FILE \
         -e REPO \
         -e WEBSITE_DIRECTORY \
         --rm "${IMAGE:-grafana/docs-base:latest}" \
         /bin/bash \
         -c '
if [[ "${INDEX_FILE}" == "true" ]]; then
  echo "Creating custom _index.md" && \
  cat > "/hugo/content/docs/${REPO}/_index.md" <<EOF
---
type: redirect
redirectURL: /docs/${REPO}/latest/
versioned: true
---
EOF
fi
cat "/hugo/content/docs/${REPO}/_index.md"
HUGO_SSI=false hugo --environment=docs --destination=dist/ --baseURL= --minify
'
# End legacy input.
else
  # All input comes from environment variables that are capitalized by convention in this script.
  readonly SOURCES="${SOURCES:-[]}"
  readonly BRANCH="${BRANCH:-}"

  if ! jq -e . <<<"${SOURCES}" >/dev/null; then
    echo "SOURCES environment variable is not valid JSON"

    exit 1
  fi

  if [[ -z "${BRANCH+x}" ]]; then
    echo "BRANCH environment variable is not set. It should be the PR branch name."

    exit 1
  fi

  function checkout_directory {
    local repo=$1
    local ref=$2
    local sanitized_ref="${ref//[^A-Za-z0-9._-]/_}"

    if [[ -z "${ref}" ]]; then
      echo "src/${repo}"
    else
      echo "src/${repo}__${sanitized_ref}"
    fi
  }

  function normalize_source_directory_for_sparse_checkout {
    local source_directory=$1

    if [[ "${source_directory}" == *"<LATEST>"* ]]; then
      echo "${source_directory%/<LATEST>*}"
    else
      echo "${source_directory}"
    fi
  }

  function sparse_checkout_paths {
    local repo=$1
    local ref=$2

    jq -r --arg repo "${repo}" --arg ref "${ref}" \
      '.[] | select((.repo // "") == $repo and ((.ref // "") == $ref)) | (.source_directory // "")' <<<"${SOURCES}" \
      | while IFS= read -r source_directory; do
          normalize_source_directory_for_sparse_checkout "${source_directory}"
        done \
      | awk 'NF && !seen[$0]++'
  }

  # Clone a repository to a specific directory.
  function clone {
    local repo=$1
    local ref=$2
    local directory=$3
    local checkout_ref="${ref:-${BRANCH}}"
    local -a sparse_paths=()

    if [[ -d "${directory}" ]]; then
      echo "Directory ${directory} already exists, skipping clone"

      return
    fi

    while IFS= read -r sparse_path; do
      if [[ -n "${sparse_path}" ]]; then
        sparse_paths+=("${sparse_path}")
      fi
    done < <(sparse_checkout_paths "${repo}" "${ref}")

    if ! gh repo clone "grafana/${repo}" "${directory}" -- --depth=1 --filter=blob:none --sparse --branch "${checkout_ref}"; then
      gh repo clone "grafana/${repo}" "${directory}" -- --depth=1 --filter=blob:none --sparse
      (
        cd "${directory}"
        git fetch --depth=1 --filter=blob:none origin "${checkout_ref}"
        git checkout --detach FETCH_HEAD
      )
    fi

    if [[ ${#sparse_paths[@]} -gt 0 ]]; then
      (
        cd "${directory}"
        git sparse-checkout set "${sparse_paths[@]}"
      )
    fi
  }

  # Find the highest semantic version directory in a given path
  function find_latest_version {
    local base_path=$1
    local highest_version=""

    # Look for directories matching semantic version pattern (vX.Y.Z or vX.Y.x)
    while IFS= read -r dir; do
      if [[ -z "${highest_version}" ]]; then
        highest_version="${dir}"
      else
        # Compare versions - extract major, minor, patch
        local current_major current_minor current_patch
        local highest_major highest_minor highest_patch

        # Extract version numbers from current directory
        if [[ "${dir}" =~ ^v([0-9]+)\.([0-9]+)\.(x|[0-9]+)$ ]]; then
          current_major="${BASH_REMATCH[1]}"
          current_minor="${BASH_REMATCH[2]}"
          current_patch="${BASH_REMATCH[3]}"
          [[ "${current_patch}" == "x" ]] && current_patch="9999"
        else
          continue
        fi

        # Extract version numbers from highest so far
        if [[ "${highest_version}" =~ ^v([0-9]+)\.([0-9]+)\.(x|[0-9]+)$ ]]; then
          highest_major="${BASH_REMATCH[1]}"
          highest_minor="${BASH_REMATCH[2]}"
          highest_patch="${BASH_REMATCH[3]}"
          [[ "${highest_patch}" == "x" ]] && highest_patch="9999"
        fi

        # Compare versions
        if (( current_major > highest_major )) || \
           (( current_major == highest_major && current_minor > highest_minor )) || \
           (( current_major == highest_major && current_minor == highest_minor && current_patch > highest_patch )); then
          highest_version="${dir}"
        fi
      fi
    done < <(find "${base_path}" -maxdepth 1 -type d -name 'v*' -printf '%f\n' 2>/dev/null | sort)

    echo "${highest_version}"
  }

  # Replace <LATEST> placeholder with the actual latest version
  function resolve_latest_placeholder {
    local path=$1
    local repo_base=$2

    if [[ "${path}" == *"<LATEST>"* ]]; then
      # Extract the parent directory path before <LATEST>
      local parent_path="${path%/<LATEST>*}"
      local remaining_path="${path#*<LATEST>}"

      # Find the latest version in the parent directory
      local full_parent_path="${repo_base}/${parent_path}"
      local latest_version
      latest_version="$(find_latest_version "${full_parent_path}")"

      if [[ -n "${latest_version}" ]]; then
        echo "${parent_path}/${latest_version}${remaining_path}"
      else
        echo "Warning: No version directories found in ${full_parent_path}, using path as-is" >&2
        echo "${path}"
      fi
    else
      echo "${path}"
    fi
  }

  # Check out all the source repositories defined in SOURCES.
  function check_out_sources {
    declare -A seen=()
    index_files=()
    while IFS=$'\x1f' read -r repo ref; do
      if [[ -z "${repo}" ]]; then
        continue
      fi

      directory="$(checkout_directory "${repo}" "${ref}")"
      if [[ -n "${seen[${directory}]+x}" ]]; then
        continue
      fi
      seen["${directory}"]=1
      clone "${repo}" "${ref}" "${directory}"
    done < <(jq -r '.[] | [(.repo // ""), (.ref // "")] | join("\u001f")' <<<"${SOURCES}")
  }

  # Create an entrypoint script for the container.
  function prepare_entrypoint {
    tempfile="$(mktemp -t deploy-preview.XXX)"
    # Pull out the relevant fields from the JSON because the grafana/docs-base image doesn't have jq.
    index_files=()
    while read -r index_file relative_prefix; do
      if [[ "${index_file}" != 'null' ]]; then
        index_files+=("${index_file}:${relative_prefix}")
      fi
    done < <(jq -r '.[] | "\(.index_file) \(.relative_prefix)"' <<<"${SOURCES}")
    cat <<EOSCRIPT >"${tempfile}"
#!/usr/bin/env bash

# Create an index file to redirect a project root to the correct versioned URL.
for pair in ${index_files[@]}; do
  IFS=':' read -r index_file relative_prefix <<<"\${pair}"
  dst="/hugo/\${index_file}"
  parent="\${dst%/*}"
  echo "Creating custom index: \${dst} -> \${relative_prefix}"

  title="\${dst%/*}"
  while [[ -n "\${parent}" ]]; do
    if [[ ! -f "\${parent}/_index.md" ]]; then
       cat > "\${parent}/_index.md" <<EOPARENT
---
title: \${title}
---

# \${title}

{{< section >}}
EOPARENT
    fi
    parent="\${parent%/*}"
  done

  cat > "\${dst}" <<EOINDEX
---
type: redirect
redirectURL: \${relative_prefix}
versioned: true
---
EOINDEX
  cat "\${dst}"
done

HUGO_SSI=false hugo --environment=docs --destination=dist/ --baseURL= --minify
EOSCRIPT
    chmod +x "${tempfile}"
  }

  # Add mounts to the volumes variable.
  function configure_volumes {
    volumes=("--volume=${PWD}/dist:/hugo/dist" "--volume=${tempfile}:/entrypoint:z")
    while IFS=$'\x1f' read -r repo ref source_directory website_directory; do
      directory="$(checkout_directory "${repo}" "${ref}")"
      resolved_source_directory=$(resolve_latest_placeholder "${source_directory}" "${PWD}/${directory}")
      volumes+=("--volume=${PWD}/${directory}/${resolved_source_directory}:/hugo/${website_directory}:z")
    done < <(jq -r '.[] | [(.repo // ""), (.ref // ""), (.source_directory // ""), (.website_directory // "")] | join("\u001f")' <<<"${SOURCES}")
  }

  # Prepare the command to run the container.
  function prepare_cmd {
    cat <<EOF
docker run \
${volumes[@]} \
--rm ${IMAGE:-grafana/docs-base:latest} \
/entrypoint
EOF
  }

  check_out_sources
  prepare_entrypoint
  declare -a volumes; configure_volumes; readonly volumes
  cmd=$(prepare_cmd)

  echo "${cmd}"
  ${cmd}
fi
